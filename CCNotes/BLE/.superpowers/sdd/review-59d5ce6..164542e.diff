+.flow-node__header{padding:10px 16px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;color:var(--text);flex-wrap:wrap;}
+.flow-node__header-icon{flex-shrink:0;width:24px;height:24px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;font-weight:700;}
+.flow-node__detail{padding:10px 16px;font-size:12px;color:var(--text-secondary);line-height:1.7;border-top:1px solid var(--border);display:none;}
+.flow-node.expanded .flow-node__detail{display:block;}
+.flow-arrow{display:flex;flex-direction:column;align-items:center;padding:4px 0;color:var(--text-secondary);font-size:11px;}
+.flow-arrow__line{width:2px;height:20px;background:var(--border);}
+.flow-arrow__arrowhead{font-size:10px;margin-top:-2px;}
+
+/* ==================== Flowchart — Auth Branch Columns (Task 7) ==================== */
+.flow-branch{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin:12px 0 16px;}
+@media(max-width:700px){.flow-branch{grid-template-columns:repeat(2,1fr);}}
+.flow-branch-col{border:1px solid var(--border);border-radius:8px;overflow:hidden;background:var(--surface);}
+.flow-branch-col__header{padding:10px 12px;font-size:13px;font-weight:600;text-align:center;color:#fff;}
+.flow-branch-col__body{padding:10px 12px;font-size:12px;color:var(--text-secondary);line-height:1.7;}
+
+/* ==================== Encryption Range Bar (Task 7) ==================== */
+.enc-range{margin:12px 0 16px;max-width:600px;}
+.enc-range__bar{display:flex;height:48px;border-radius:6px;overflow:hidden;border:1px solid var(--border);margin-bottom:12px;}
+.enc-range__seg{display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:10px;color:#fff;font-weight:600;transition:opacity .15s;position:relative;min-width:0;}
