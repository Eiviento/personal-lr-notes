+  padding:5px 14px;border:1px solid var(--border);
+  border-radius:5px;background:var(--bg);color:var(--text);
+  font-size:12px;cursor:pointer;font-family:var(--font);
+  transition:background .15s;
+}
+.timeline-btn:hover{background:var(--surface-hover);}
+
+/* ==================== Protocol Stack (Task 7) ==================== */
+.protocol-stack{display:flex;flex-direction:column;gap:8px;margin:12px 0 16px;max-width:320px;}
+.stack-layer{display:flex;flex-direction:column;justify-content:center;align-items:center;padding:12px 16px;border-radius:8px;cursor:pointer;transition:transform .15s,box-shadow .15s;color:#fff;min-height:48px;}
+.stack-layer:hover{transform:translateX(4px);box-shadow:0 2px 12px rgba(0,0,0,.15);}
+.stack-layer__name{font-size:14px;font-weight:700;}
+.stack-layer__tag{font-size:11px;opacity:.9;margin-top:2px;}
+
+/* ==================== Flowchart — Pairing Phases (Task 7) ==================== */
+.flowchart{display:flex;flex-direction:column;align-items:center;gap:0;margin:12px 0 16px;width:100%;max-width:540px;}
+.flow-node{width:100%;border:1px solid var(--border);border-radius:8px;overflow:hidden;cursor:pointer;transition:box-shadow .15s,margin .15s;background:var(--bg);}
