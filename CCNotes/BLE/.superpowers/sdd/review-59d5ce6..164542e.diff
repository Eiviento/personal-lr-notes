+  // ==================== renderRefTables (Task 6) ====================
+  function renderRefTables(container) {
+    container.className += ' ref-tables-container';
+
+    // ---- Tab bar ----
+    var tabBar = document.createElement('div');
+    tabBar.className = 'ref-tab-bar';
+    container.appendChild(tabBar);
+
+    // ---- Search input ----
+    var searchWrap = document.createElement('div');
+    searchWrap.className = 'ref-search';
+    var searchInput = document.createElement('input');
+    searchInput.className = 'ref-search-input';
+    searchInput.type = 'text';
+    searchInput.placeholder = '搜索当前表...';
+    searchWrap.appendChild(searchInput);
+    container.appendChild(searchWrap);
+
+    // ---- Table wrapper ----
+    var tableWrapper = document.createElement('div');
+    tableWrapper.className = 'ref-table-wrapper';
+    container.appendChild(tableWrapper);
+
+    // ---- Count display ----
+    var countEl = document.createElement('div');
+    countEl.className = 'ref-count';
+    container.appendChild(countEl);
+
+    // ---- State ----
+    var currentId = REF_TABLES[0].id;
+    var filterText = '';
+
+    // ---- Build tabs ----
+    REF_TABLES.forEach(function(t) {
+      var btn = document.createElement('button');
+      btn.className = 'ref-tab-btn' + (t.id === currentId ? ' active' : '');
+      btn.textContent = t.label;
+      btn.addEventListener('click', function() {
+        tabBar.querySelectorAll('.ref-tab-btn').forEach(function(b) { b.classList.remove('active'); });
+        btn.classList.add('active');
+        currentId = t.id;
+        renderTable(t, filterText);
+      });
+      tabBar.appendChild(btn);
+    });
+
+    // ---- Render function ----
+    function renderTable(table, filter) {
+      filter = filter.toLowerCase().trim();
+      var filteredRows = [];
+      table.rows.forEach(function(row) {
+        var match = !filter ||
+          row.some(function(cell) { return cell.toLowerCase().indexOf(filter) !== -1; }) ||
+          (table.id === 'll-control' && row[0].toLowerCase().indexOf(filter) !== -1);
+        if (match) { filteredRows.push(row); }
+      });
+
+      var html = '<table class="ref-table"><thead><tr>';
+      table.headers.forEach(function(h) { html += '<th>' + h + '</th>'; });
+      html += '</tr></thead><tbody>';
+      filteredRows.forEach(function(row) {
+        html += '<tr>';
+        row.forEach(function(cell) { html += '<td>' + cell + '</td>'; });
+        html += '</tr>';
+      });
+      html += '</tbody></table>';
+      tableWrapper.innerHTML = html;
+      countEl.textContent = '显示 ' + filteredRows.length + ' / ' + table.rows.length + ' 条';
+    }
+
+    // ---- Search handler ----
+    searchInput.addEventListener('input', function() {
+      filterText = this.value;
+      var table = REF_TABLES.filter(function(t) { return t.id === currentId; })[0];
+      renderTable(table, filterText);
+    });
+
+    // ---- Initial render ----
+    renderTable(REF_TABLES[0], '');
+  }
