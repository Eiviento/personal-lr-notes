+.ref-table th,.ref-table td{border:1px solid var(--border);padding:7px 11px;text-align:left;vertical-align:top;}
+.ref-table th{background:var(--surface);font-weight:600;color:var(--text);white-space:nowrap;}
+.ref-table td{color:var(--text-secondary);}
+.ref-table tr:nth-child(even) td{background:var(--surface);}
+.ref-table code{font-family:var(--font-mono);font-size:12px;background:var(--surface-hover);padding:1px 5px;border-radius:3px;color:var(--cyan);}
+.ref-table tr.ref-hidden{display:none;}
+.ref-count{font-size:12px;color:var(--text-secondary);margin-top:6px;}
+
+/* ==================== Timeline Component ==================== */
