+  // --- Render a single bit layout ---
+  function renderBitLayout(layoutDef) {
+    var container = document.createElement('div');
+    container.className = 'bit-layout';
+
+    // Title
+    var title = document.createElement('div');
+    title.className = 'bit-layout__title';
+    title.textContent = layoutDef.title;
+    container.appendChild(title);
+
+    // Color bar
+    var bar = document.createElement('div');
+    bar.className = 'bit-layout__bar';
+    var total = layoutDef.bits;
+
+    layoutDef.fields.forEach(function(field, idx) {
+      var seg = document.createElement('div');
+      seg.className = 'bit-layout__segment';
+      seg.setAttribute('data-field', idx);
+      seg.style.cssText = 'flex:' + field.bits + ';background:' + field.color + ';';
+
+      var label = document.createElement('span');
+      label.className = 'bit-layout__seg-label';
+      label.textContent = field.name;
+      seg.appendChild(label);
+
+      var bitsLabel = document.createElement('span');
+      bitsLabel.className = 'bit-layout__seg-bits';
+      bitsLabel.textContent = field.bits + 'b';
+      seg.appendChild(bitsLabel);
+
+      bar.appendChild(seg);
+    });
+    container.appendChild(bar);
+
+    // Detail table
+    var table = document.createElement('table');
+    table.className = 'bit-layout__table';
+    var thead = document.createElement('thead');
+    thead.innerHTML = '<tr><th>字段</th><th>位宽</th><th>位范围</th><th>说明</th></tr>';
+    table.appendChild(thead);
+
+    var tbody = document.createElement('tbody');
+    var cumBits = 0;
+
+    layoutDef.fields.forEach(function(field, idx) {
+      var row = document.createElement('tr');
+      row.setAttribute('data-field', idx);
+
+      var highBit = total - cumBits - 1;
+      var lowBit = total - cumBits - field.bits;
+      cumBits += field.bits;
+
+      var rangeStr = (highBit === lowBit) ? '[' + highBit + ']' : '[' + highBit + ':' + lowBit + ']';
+
+      var bitsStr = field.bits + ' bit';
+      if (field.bits >= 8) {
+        bitsStr += ' (' + (field.bits / 8) + ' B)';
+      }
+
+      var descHtml = field.desc;
+      if (field.values) {
+        descHtml += '<div class="bit-layout__values">';
+        var keys = Object.keys(field.values);
+        for (var k = 0; k < keys.length; k++) {
+          descHtml += '<code>' + keys[k] + '</code> = ' + field.values[keys[k]];
+          if (k < keys.length - 1) descHtml += '<br>';
+        }
+        descHtml += '</div>';
+      }
+
+      row.innerHTML =
+        '<td style="border-left:3px solid ' + field.color + ';"><strong>' + field.name + '</strong></td>' +
+        '<td>' + bitsStr + '</td>' +
+        '<td><code>' + rangeStr + '</code></td>' +
+        '<td>' + descHtml + '</td>';
+      tbody.appendChild(row);
+    });
+
+    table.appendChild(tbody);
+    container.appendChild(table);
+
+    // Hover linkage: bar segments <-> table rows
+    var segments = container.querySelectorAll('.bit-layout__segment');
+    var rows = container.querySelectorAll('.bit-layout__table tbody tr');
+
+    function highlight(idx) {
+      if (segments[idx]) segments[idx].classList.add('is-highlighted');
+      if (rows[idx]) rows[idx].classList.add('is-highlighted');
+    }
+    function unhighlight(idx) {
+      if (segments[idx]) segments[idx].classList.remove('is-highlighted');
+      if (rows[idx]) rows[idx].classList.remove('is-highlighted');
+    }
+
+    segments.forEach(function(seg, i) {
+      seg.addEventListener('mouseenter', function() { highlight(i); });
+      seg.addEventListener('mouseleave', function() { unhighlight(i); });
+    });
+    rows.forEach(function(row, i) {
+      row.addEventListener('mouseenter', function() { highlight(i); });
+      row.addEventListener('mouseleave', function() { unhighlight(i); });
+    });
+
+    return container;
+  }
