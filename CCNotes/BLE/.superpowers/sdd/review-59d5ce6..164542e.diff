+.enc-range__seg-pct{font-size:8px;opacity:.8;}
+.enc-range__seg-note{position:absolute;top:-14px;left:50%;transform:translateX(-50%);font-size:8px;white-space:nowrap;color:var(--orange);font-weight:700;}
+.enc-range__legend{margin-top:16px;font-size:12px;color:var(--text-secondary);line-height:1.7;}
+.enc-range__legend-item{display:flex;align-items:flex-start;gap:8px;margin-bottom:6px;}
+.enc-range__legend-swatch{width:14px;height:14px;border-radius:3px;flex-shrink:0;border:1px solid var(--border);margin-top:3px;}
+
